# Public site URL (for sitemap, canonicals, share links, auth redirects). Production: https://ryan-realty.com (no trailing slash)
# NEXT_PUBLIC_SITE_URL=https://ryan-realty.com

# Optional: site-wide business name and contact email (footer, copyright, mailto link)
# Set these in .env.local (and in Vercel env for production). Logged-in visitor name/email comes from Supabase Auth (Google or account profile), not from here.
# NEXT_PUBLIC_SITE_OWNER_NAME=Ryan Realty
# NEXT_PUBLIC_SITE_OWNER_EMAIL=hello@ryanrealty.com

# Footer social links (copy exact URLs from ryanrealty.com / ryan-realty.com so icons go to the correct profiles)
# NEXT_PUBLIC_SOCIAL_FACEBOOK_URL=https://www.facebook.com/...
# NEXT_PUBLIC_SOCIAL_INSTAGRAM_URL=https://www.instagram.com/...
# NEXT_PUBLIC_SOCIAL_LINKEDIN_URL=https://www.linkedin.com/company/...

# Supabase (from your project: Settings → API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Mapbox: reserved for future use if switching from Google Maps. Not currently referenced.
# NEXT_PUBLIC_MAPBOX_ACCESS_TOKEN=

# Spark API (listings feed – https://sparkplatform.com/docs)
SPARK_API_KEY=
# Replication keys must use the replication endpoint (required if you get 403 "use replication.sparkapi.com")
SPARK_API_BASE_URL=https://replication.sparkapi.com/v1
# Optional: for non-replication keys only, omit above and the default is https://sparkapi.com/v1
# Optional: use OAuth instead of Bearer if your MLS requires it
# SPARK_AUTH_SCHEME=OAuth
# Vercel cron (every 15 min) calls GET /api/sync-spark with Authorization: Bearer <CRON_SECRET>
# Set CRON_SECRET in Vercel env so the cron job is authenticated.
CRON_SECRET=
# Optional: secret for manual POST /api/sync-spark (header: x-sync-secret)
# SYNC_SECRET=

# Hero/banner images for city and community pages (Unsplash)
# https://unsplash.com/developers — create an app and use the Access Key
# UNSPLASH_ACCESS_KEY=

# FollowUp Boss CRM — sync/track users when they sign in with Google
# Get API key: Follow Up Boss → Admin → API (use as username, password empty)
# FOLLOWUPBOSS_API_KEY=
# Optional: register your system at https://apps.followupboss.com/system-registration for X-System / X-System-Key
# FOLLOWUPBOSS_SYSTEM=
# FOLLOWUPBOSS_SYSTEM_KEY=
# Email click identity bridge: URL param name from FUB email links (e.g. _fuid=123). When present, we link the visit to that contact.
# NEXT_PUBLIC_FUB_EMAIL_CLICK_PARAM=_fuid

# Google Analytics 4 — loaded directly in code (no GTM setup required). From analytics.google.com → Admin → Data streams.
# NEXT_PUBLIC_GA4_MEASUREMENT_ID=G-XXXXXXXXXX
# Optional: Google Tag Manager container ID if you use GTM for other tags
# NEXT_PUBLIC_GTM_CONTAINER_ID=GTM-XXXXXXX
# Optional: Google AdSense client ID (e.g. ca-pub-XXXXXXXXXXXXXXXX)
# NEXT_PUBLIC_ADSENSE_CLIENT_ID=ca-pub-XXXXXXXXXXXXXXXX

# Google Ads — tag ID from ads.google.com → Tools → Setup → Conversions (e.g. AW-123456789). Required for Ads tracking.
# NEXT_PUBLIC_GOOGLE_ADS_ID=AW-123456789
# Optional: conversion "send_to" values from Google Ads conversion actions (Tools → Conversions → create action → Get snippet). Enables conversion events for lead and sign-up.
# NEXT_PUBLIC_GOOGLE_ADS_CONVERSION_LEAD=AW-123456789/AbCdEfGhIjK
# NEXT_PUBLIC_GOOGLE_ADS_CONVERSION_SIGNUP=AW-123456789/XyZ123AbC

# Meta (Facebook) Pixel — optional. When set + cookie consent, loads pixel and sends PageView + ViewContent/Lead/CompleteRegistration. From Events Manager → Data sources → Pixel → Settings → Pixel ID.
# NEXT_PUBLIC_META_PIXEL_ID=1234567890123456

# Google OAuth (Cloud Console → Credentials → OAuth 2.0 Client ID, type Web). For server-side Google API access (GA4 Data API, AdSense API, Tag Manager API). Do not use NEXT_PUBLIC_ — server only.
# GOOGLE_OAUTH_CLIENT_ID=xxxxxxxxxx.apps.googleusercontent.com
# GOOGLE_OAUTH_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxxxxxxxxxxxxxx

# GA4 Data API (admin dashboard live metrics). See docs/GA4_SERVICE_ACCOUNT_SETUP.md. Property ID = numeric from GA4 Admin → Property settings. Private key: use literal \n in the value.
# GOOGLE_GA4_PROPERTY_ID=527333348
# GOOGLE_SERVICE_ACCOUNT_CLIENT_EMAIL=xxx@yyy.iam.gserviceaccount.com
# GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Photo classification for hero selection (GPT-4o Vision). If unset, classification is skipped; hero falls back to Unsplash/banner.
# OPENAI_API_KEY=

# Replicate — AI headshot generation on Admin Broker page (fofr/face-to-many). If unset, "Generate professional headshot" is disabled.
# Get token: https://replicate.com/account/api-tokens
# REPLICATE_API_TOKEN=

# Synthesia — broker intro video generation (Admin Broker page). Creator plan or above. If unset, "Generate intro video (Synthesia)" is hidden.
# Get key: https://app.synthesia.io → Settings → API
# SYNTHESIA_API_KEY=

# xAI Grok API — powers AI chat ("Chat With Us") and AI text generation. If unset, AI features return 503.
# Get key: https://console.x.ai
# XAI_API_KEY=

# Upstash Redis — rate limiting for API routes (middleware + per-route). If unset, rate limiting is disabled (open access).
# Create a Redis database at https://console.upstash.com, then copy REST URL and token.
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# Google Maps — property maps, comparison map. If unset, maps won't load.
# NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Resend — transactional email (CMA delivery, contact form notifications, valuation responses).
# Get key: https://resend.com/api-keys
# RESEND_API_KEY=
# Admin notification recipient email
# ADMIN_EMAIL=

# Sentry — error tracking and performance monitoring. If unset, errors are only logged to console.
# SENTRY_DSN=
