{
  "name": "nextjs",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "powershell -ExecutionPolicy Bypass -File scripts/run-dev.ps1",
    "restart": "npm run dev",
    "build": "next build",
    "build:clean-local": "powershell -ExecutionPolicy Bypass -Command \"if (Test-Path '.next/dev') { Remove-Item -Recurse -Force '.next/dev' }\" && next build",
    "start": "next start",
    "lint": "eslint",
    "lint:design-tokens": "node scripts/lint-design-tokens.js",
    "lint:design-tokens:all": "node scripts/lint-design-tokens.js --all",
    "lint:seo-routes": "node scripts/check-seo-routes.mjs && node scripts/check-seo-authoring.mjs",
    "ci:design-tokens": "node scripts/lint-design-tokens.js --base-diff",
    "perf": "npx lighthouse http://localhost:3000 --output=html --output-path=./.lighthouse-report.html --chrome-flags=\"--headless\" --only-categories=performance --quiet || true",
    "start:ci": "next start -p 3000",
    "quality:lighthouse": "lhci autorun --config=./lighthouserc.cjs",
    "quality:a11y": "pa11y-ci --config ./.pa11yci.json",
    "ci:lighthouse": "start-server-and-test start:ci http://127.0.0.1:3000 quality:lighthouse",
    "ci:a11y": "start-server-and-test start:ci http://127.0.0.1:3000 quality:a11y",
    "quality:local": "npm run ci:design-tokens && npm run test",
    "quality:local:strict": "npm run ci:design-tokens && npm run test && npm run build:clean-local",
    "quality:local:full": "npm run ci:design-tokens && npm run lint && npm run test && npm run build && npm run ci:lighthouse && npm run ci:a11y",
    "supabase": "supabase",
    "db:push": "supabase db push",
    "db:push:all": "supabase db push --include-all",
    "db:guard": "node scripts/check-supabase-migration-drift.mjs",
    "db:migration": "supabase migration new",
    "db:add-team-image": "node scripts/add-team-image-column.mjs",
    "sync:full": "node scripts/run-full-sync.mjs",
    "sync:year": "node scripts/run-year-sync.mjs",
    "test": "vitest run",
    "test:history": "node scripts/test-listing-history.mjs",
    "vercel:env": "node scripts/sync-vercel-env.mjs",
    "prepare": "husky"
  },
  "dependencies": {
    "@google-analytics/data": "^5.2.1",
    "@googlemaps/markerclusterer": "^2.6.2",
    "@heroicons/react": "^2.2.0",
    "@hugeicons/core-free-icons": "^4.0.0",
    "@hugeicons/react": "^1.1.6",
    "@react-email/components": "^1.0.8",
    "@react-google-maps/api": "^2.20.8",
    "@react-pdf/renderer": "^4.2.0",
    "@sentry/nextjs": "^10.42.0",
    "@serwist/next": "^9.5.6",
    "@supabase/ssr": "^0.9.0",
    "@supabase/supabase-js": "2.98.0",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.37.0",
    "canvas-confetti": "^1.9.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "embla-carousel-react": "^8.6.0",
    "geist": "^1.3.1",
    "googleapis": "^171.4.0",
    "isomorphic-dompurify": "^3.3.0",
    "next": "16.1.6",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "react": "19.2.3",
    "react-day-picker": "^9.14.0",
    "react-dom": "19.2.3",
    "react-resizable-panels": "^4.7.2",
    "recharts": "^2.15.4",
    "resend": "^6.9.3",
    "shadcn": "^4.0.6",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "vaul": "^1.1.2",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@lhci/cli": "^0.15.1",
    "@swc/helpers": "^0.5.19",
    "@tailwindcss/postcss": "^4",
    "@types/canvas-confetti": "^1.9.0",
    "@types/node": "20.19.37",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "husky": "^9.1.7",
    "pa11y-ci": "^4.1.0",
    "pg": "^8.20.0",
    "serwist": "^9.5.6",
    "start-server-and-test": "^2.1.5",
    "supabase": "^2.76.16",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.0.18"
  }
}
