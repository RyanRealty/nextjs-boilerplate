{
  "name": "nextjs",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "powershell -ExecutionPolicy Bypass -File scripts/run-dev.ps1",
    "dev:unix": "next dev",
    "install:macos": "PUPPETEER_SKIP_DOWNLOAD=1 npm ci",
    "restart": "npm run dev",
    "build": "next build",
    "build:clean-local": "powershell -ExecutionPolicy Bypass -Command \"if (Test-Path '.next/dev') { Remove-Item -Recurse -Force '.next/dev' }\" && next build",
    "start": "next start",
    "lint": "eslint",
    "lint:design-tokens": "node scripts/lint-design-tokens.js",
    "lint:design-tokens:all": "node scripts/lint-design-tokens.js --all",
    "lint:seo-routes": "node scripts/check-seo-routes.mjs && node scripts/check-seo-authoring.mjs",
    "ci:design-tokens": "node scripts/lint-design-tokens.js --base-diff",
    "perf": "npx lighthouse http://localhost:3000 --output=html --output-path=./.lighthouse-report.html --chrome-flags=\"--headless\" --only-categories=performance --quiet || true",
    "start:ci": "next start -p 3000",
    "quality:lighthouse": "lhci autorun --config=./lighthouserc.cjs",
    "quality:a11y": "pa11y-ci --config ./.pa11yci.json",
    "ci:lighthouse": "start-server-and-test start:ci http://127.0.0.1:3000 quality:lighthouse",
    "ci:a11y": "start-server-and-test start:ci http://127.0.0.1:3000 quality:a11y",
    "quality:local": "npm run ci:design-tokens && npm run test",
    "quality:local:strict": "npm run ci:design-tokens && npm run test && npm run build:clean-local",
    "quality:local:full": "npm run ci:design-tokens && npm run lint && npm run test && npm run build && npm run ci:lighthouse && npm run ci:a11y",
    "supabase": "supabase",
    "db:push": "supabase db push",
    "db:push:all": "supabase db push --include-all",
    "db:guard": "node scripts/check-supabase-migration-drift.mjs",
    "db:migration": "supabase migration new",
    "db:add-team-image": "node scripts/add-team-image-column.mjs",
    "sync:full": "node scripts/run-full-sync.mjs",
    "sync:strict-last-ask": "node scripts/sync-strict-verify-last-ask.mjs",
    "test": "vitest run",
    "orchestrate": "npx tsx scripts/orchestrate.ts",
    "orchestrate:status": "npx tsx scripts/orchestrate.ts status",
    "orchestrate:next": "npx tsx scripts/orchestrate.ts next",
    "orchestrate:report": "npx tsx scripts/orchestrate.ts report",
    "orchestrate:validate": "npx tsx scripts/orchestrate.ts validate",
    "quality:full": "npm run lint && npm run lint:design-tokens && npm run lint:seo-routes && npm run test && npm run build",
    "health:record": "npx tsx scripts/track-build-health.ts",
    "health:compare": "npx tsx scripts/track-build-health.ts compare",
    "health:history": "npx tsx scripts/track-build-health.ts history",
    "coverage:report": "npx tsx scripts/generate-test-stubs.ts report",
    "coverage:generate": "npx tsx scripts/generate-test-stubs.ts generate",
    "test:e2e": "npx playwright test --project=chromium",
    "test:e2e:all": "npx playwright test",
    "test:e2e:ui": "npx playwright test --ui",
    "test:e2e:update-snapshots": "npx playwright test --update-snapshots",
    "docs:check": "npx tsx scripts/check-docs-freshness.ts",
    "docs:check:summary": "npx tsx scripts/check-docs-freshness.ts --summary",
    "test:history": "node scripts/test-listing-history.mjs",
    "video:reprocess:hero": "node scripts/reprocess-hero-video.mjs",
    "video:cascade-peaks:setup": "node scripts/bootstrap-cascade-peaks-video.mjs",
    "video:cascade-peaks:verify-tiles": "npm run verify-tiles --prefix video/cascade-peaks",
    "video:cascade-peaks:studio": "npm run start --prefix video/cascade-peaks",
    "video:cascade-peaks:render": "npm run build --prefix video/cascade-peaks",
    "video:cascade-peaks:render:4k": "npm run build:4k --prefix video/cascade-peaks",
    "video:cascade-peaks:render:photo-fast": "npm run build:photo-fast --prefix video/cascade-peaks",
    "video:cascade-peaks:finish": "bash video/cascade-peaks/finish_v1.sh",
    "video:evergreen:setup": "node video/evergreen-education/scripts/setup.mjs",
    "video:evergreen:equity": "node video/evergreen-education/scripts/compute-equity-table.mjs",
    "video:evergreen:illustrations": "node video/evergreen-education/scripts/generate-illustrations.mjs",
    "video:evergreen:scout-grok": "node video/evergreen-education/scripts/scout-grok-video.mjs",
    "video:evergreen:music": "node video/evergreen-education/scripts/fetch-music.mjs",
    "video:evergreen:synth-vo": "node video/evergreen-education/scripts/synth-vo.mjs",
    "video:evergreen:render": "node video/evergreen-education/scripts/render.mjs",
    "video:evergreen:qc": "node video/evergreen-education/scripts/qc.mjs",
    "video:evergreen:email": "node video/evergreen-education/scripts/send-delivery-email.mjs",
    "video:evergreen:studio": "npm run studio --prefix video/evergreen-education",
    "video:listing-tour:setup": "node scripts/bootstrap-listing-tour-video.mjs",
    "video:listing-tour:prepare": "npx tsx video/listing-tour/scripts/prepare-tour.ts",
    "video:listing-tour:studio": "npm run start --prefix video/listing-tour",
    "video:listing-tour:render": "npm run render --prefix video/listing-tour",
    "video:listing-tour:preview:storyboard": "npm run preview:storyboard --prefix video/listing-tour",
    "video:listing-tour:fetch-caldera-broll": "node video/listing-tour/scripts/fetch-caldera-unsplash-broll.mjs",
    "env:verify": "npx tsx scripts/verify-env.ts",
    "deploy:verify": "node scripts/check-vercel-deploy.mjs",
    "env:pull-merge": "npx vercel env pull .env.vercel.pull --environment=production --yes && node scripts/merge-vercel-env-into-local.mjs",
    "vercel:env": "node scripts/sync-vercel-env.mjs",
    "vercel:env:skyslope": "node scripts/sync-vercel-env.mjs production --only=SKYSLOPE_ACCESS_KEY,SKYSLOPE_ACCESS_SECRET,SKYSLOPE_CLIENT_ID,SKYSLOPE_CLIENT_SECRET && node scripts/sync-vercel-env.mjs preview --only=SKYSLOPE_ACCESS_KEY,SKYSLOPE_ACCESS_SECRET,SKYSLOPE_CLIENT_ID,SKYSLOPE_CLIENT_SECRET",
    "vercel:env:stock": "node scripts/sync-vercel-env.mjs production --only=UNSPLASH_ACCESS_KEY,SHUTTERSTOCK_API_KEY,SHUTTERSTOCK_API_SECRET,PEXELS_API_KEY",
    "github:secrets:skyslope": "node scripts/sync-github-secrets-from-local.mjs SKYSLOPE_ACCESS_KEY SKYSLOPE_ACCESS_SECRET --optional SKYSLOPE_CLIENT_ID SKYSLOPE_CLIENT_SECRET",
    "skyslope:forms-audit": "node scripts/skyslope-forms-master-audit.mjs",
    "skyslope:forms-comprehensive-log": "node scripts/skyslope-forms-comprehensive-log.mjs",
    "skyslope:forms-rename-documents": "node scripts/skyslope-forms-rename-documents.mjs",
    "skyslope:forms-workbook": "node scripts/skyslope-forms-transaction-workbook.mjs",
    "skyslope:forms-brief": "node scripts/skyslope-forms-principal-brief-docx.mjs",
    "geocode:easy-missing": "node scripts/geocode-easy-missing-listings.mjs",
    "geocode:easy-missing:report": "node scripts/geocode-easy-progress-report.mjs",
    "backfill:close-price:history": "node scripts/backfill-close-price-from-history.mjs",
    "backfill:close-price:spark": "npx tsx scripts/backfill-close-price-from-spark.ts",
    "backfill:listing-dom": "node scripts/backfill-listing-dom-metrics.mjs",
    "prepare": "husky"
  },
  "dependencies": {
    "@google-analytics/data": "^5.2.1",
    "@googlemaps/markerclusterer": "^2.6.2",
    "@heroicons/react": "^2.2.0",
    "@hugeicons/core-free-icons": "^4.0.0",
    "@hugeicons/react": "^1.1.6",
    "@react-email/components": "^1.0.8",
    "@react-google-maps/api": "^2.20.8",
    "@react-pdf/renderer": "^4.2.0",
    "@sentry/nextjs": "^10.42.0",
    "@serwist/next": "^9.5.6",
    "@supabase/ssr": "^0.9.0",
    "@supabase/supabase-js": "2.98.0",
    "@tailwindcss/typography": "^0.5.19",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.37.0",
    "canvas-confetti": "^1.9.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "embla-carousel-react": "^8.6.0",
    "geist": "^1.3.1",
    "googleapis": "^171.4.0",
    "isomorphic-dompurify": "^3.3.0",
    "next": "16.1.6",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "react": "19.2.3",
    "react-day-picker": "^9.14.0",
    "react-dom": "19.2.3",
    "react-resizable-panels": "^4.7.2",
    "recharts": "^2.15.4",
    "resend": "^6.9.3",
    "shadcn": "^4.0.6",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "vaul": "^1.1.2",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@ffmpeg-installer/ffmpeg": "^1.1.0",
    "@lhci/cli": "^0.15.1",
    "@napi-rs/canvas": "^0.1.97",
    "@playwright/test": "1.58.2",
    "@swc/helpers": "^0.5.19",
    "@tailwindcss/postcss": "^4",
    "@types/canvas-confetti": "^1.9.0",
    "@types/node": "20.19.37",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "docx": "^9.6.1",
    "dotenv": "^17.3.1",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "fluent-ffmpeg": "^2.1.3",
    "husky": "^9.1.7",
    "pa11y-ci": "^4.1.0",
    "pdfjs-dist": "^4.10.38",
    "pg": "^8.20.0",
    "serwist": "^9.5.6",
    "start-server-and-test": "^2.1.5",
    "supabase": "^2.76.16",
    "tailwindcss": "^4",
    "tesseract.js": "^7.0.0",
    "tweetsodium": "^0.0.4",
    "typescript": "^5",
    "vitest": "^4.0.18"
  }
}
